// obj_npc_joseph
// Create Event
// Джозоф обычно находится на втором плане относительно героя.
// В интерьере паба он рисуется за барной стойкой.

npc_name = "Джозоф";
dialogue_text = "Ну что, капитан? Куда ты нас заведешь на этот раз?";
interaction_distance = 48;
show_hint = false;


// Внутри паба Джозоф должен стоять ЗА барной стойкой.
// Барная стойка лежит на обычном слое с depth = 0.
// depth = 10 значит: Джозоф рисуется позади стойки,
// но всё ещё поверх фона паба.
if (room == rm_pub_interior) {
    depth = 10;
}
else {
    // В остальных сценах Джозоф остаётся позади главного героя.
    depth = -90000;
}
